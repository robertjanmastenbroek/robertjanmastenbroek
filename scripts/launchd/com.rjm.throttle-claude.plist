<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.rjm.throttle-claude</string>

  <!-- Long-running daemon; loops internally every THROTTLE_INTERVAL seconds.
       KeepAlive ensures launchd respawns it if it crashes. -->
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/motomoto/bin/throttle-claude.sh</string>
  </array>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>

  <!-- Throttle relaunches so a broken script can't busy-loop launchd. -->
  <key>ThrottleInterval</key>
  <integer>10</integer>

  <!-- Keep this watcher itself low-priority. -->
  <key>Nice</key>
  <integer>10</integer>
  <key>LowPriorityIO</key>
  <true/>
  <key>ProcessType</key>
  <string>Background</string>

  <!-- Logs outside ~/Documents (TCC blocks bash from writing there). -->
  <key>StandardOutPath</key>
  <string>/Users/motomoto/Library/Logs/throttle_claude_launchd.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/motomoto/Library/Logs/throttle_claude_launchd.log</string>
</dict>
</plist>
