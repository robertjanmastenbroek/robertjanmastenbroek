# ════════════════════════════════════════════════════════════════════════════
# YouTube Long-Form Publisher — required environment variables
# Append these to your existing .env (which is gitignored).
# See content_engine/youtube_longform/README.md for full context.
# ════════════════════════════════════════════════════════════════════════════

# ─── Image generation — fal.ai ──────────────────────────────────────────────
# Create an account at https://fal.ai and grab your key from the dashboard.
# Cost: ~$0.14 per upload (1 hero @ 1080p + 3 thumbnails @ 720p).
FAL_KEY=

# Optional: LoRA URL after training (one-time ~$20).
# Leave empty to use pure Flux 2 Pro baseline (works but ~70% style consistency
# vs ~95% with LoRA).
FAL_BRAND_LORA_URL=
FAL_BRAND_LORA_SCALE=0.80

# ─── Render backend — Cloudinary (primary, free tier) ───────────────────────
# Sign up at https://cloudinary.com. Free tier: 25 credits/month
# ≈ 60+ 6-minute video renders. More than enough for 3×/week cadence.
#
# Preferred: use the consolidated CLOUDINARY_URL (the Cloudinary SDK auto-reads it):
#   CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
# Or use the three split vars below if that's already how your .env is set.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Render backend — Shotstack (NOT NEEDED at current volume) ──────────────
# Cloudinary free tier covers 3×/week cadence comfortably. Only enable
# Shotstack if Cloudinary hits compositing edge cases (very rare).
SHOTSTACK_API_KEY=
SHOTSTACK_ENV=stage

# ─── YouTube Data API v3 ────────────────────────────────────────────────────
# These reuse the existing RJM OAuth app. One Google account can authorize
# uploads to multiple channels — grant the existing app access to the HOLY
# RAVE channel when you create it, then refresh the token via:
#   python3 scripts/setup_youtube_oauth.py
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# The Holy Rave channel ID (optional — required only if authorizing multiple
# channels on the same OAuth app and you need to disambiguate).
YOUTUBE_HOLY_RAVE_CHANNEL_ID=

# ─── YouTube playlist auto-add ──────────────────────────────────────────────
# Optional. If set, new uploads are appended to the matching playlist based
# on the track's BPM/scripture bucket. Create these playlists manually in
# YouTube Studio first, then paste the IDs here.
YOUTUBE_PLAYLIST_TRIBAL_PSY=
YOUTUBE_PLAYLIST_ORGANIC_HOUSE=
YOUTUBE_PLAYLIST_MIDDLE_EASTERN=

# Daily quota cap (default 10,000). Only raise if Google granted an extension.
YOUTUBE_DAILY_QUOTA_CAP=10000

# ─── Smart-link / funnel instrumentation ─────────────────────────────────────
# Feature.fm creates tracked smart links with per-platform analytics (paid).
# If blank, the pipeline falls back to Odesli/Songlink (free) and finally
# to the raw Spotify URL with UTM suffix (always works).
FEATUREFM_API_KEY=
FEATUREFM_ACCOUNT_ID=

# Apple Music artist URL (used in description alongside Spotify)
APPLE_MUSIC_ARTIST_URL=https://music.apple.com/us/artist/robert-jan-mastenbroek/1875064180
